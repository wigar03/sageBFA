<?xml version = "1.0" encoding = "ISO-8859-1"?>

<!DOCTYPE application SYSTEM "dtds/application.dtd">

<!--
    application.xml: Configuración de módulos visibles en SAGE-BFA.
    
    Con generateDefaultModules=false en xava.properties, SOLO se muestran
    los módulos declarados explícitamente aquí. Esto oculta del menú las
    entidades internas (Usuario, UsuarioAdministrativo, OpcionRespuesta,
    RespuestaCandidato, PruebaAptitud, etc.) que el psicólogo no necesita ver.
-->

<application name="sageBFA">

    <!-- ═══ Módulos visibles para el Psicólogo ═══ -->
    
    <module name="ModuloPrueba">
        <model name="ModuloPrueba"/>
        <controller name="Typical"/>
    </module>

    <module name="Candidato">
        <model name="Candidato"/>
        <controller name="Candidato"/>
    </module>

    <module name="IntentoEvaluacion">
        <model name="IntentoEvaluacion"/>
        <controller name="Typical"/>
    </module>

</application>
